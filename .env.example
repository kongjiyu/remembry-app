# Remembry Environment Configuration
# Copy this file to .env.local and fill in your values

# =============================================================================
# GEMINI AI
# =============================================================================
# Get your API key from https://aistudio.google.com/app/apikey
# Optional fallback (recommended to leave empty and set key per user in Settings)
GEMINI_API_KEY=

# =============================================================================
# SUPABASE - Local Development
# =============================================================================
# For local Supabase (run via `supabase start` or Docker):
# URL: http://127.0.0.1:54321
# Service role key: (run `supabase status` to get it)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your_local_supabase_service_role_key_here

# For cloud Supabase, use these instead:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_cloud_service_role_key
