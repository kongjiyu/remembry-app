# Auto-detect text files and normalize to LF
* text=auto

# Source files - always LF
*.rs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary assets - no normalization
*.png binary
*.ico binary
*.icns binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary